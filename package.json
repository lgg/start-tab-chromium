{
  "name": "start-tab",
  "version": "2.0.0",
  "description": "Start Tab for Chromium Browsers is a personal website blocker with a configurable custom new tab experience.",
  "repository": "https://github.com/lgg/start-tab-chromium.git",
  "author": "Rahul Gupta-Iwasaki, Fedor (https://github.com/lgg)",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "build:blocker-only": "node build.mjs --without-newtab --outdir=build-blocker-only",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf build build-blocker-only"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
